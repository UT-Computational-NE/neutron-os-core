flowchart TB
    subgraph Reactor["TRIGA REACTOR"]
        style Reactor fill:#e65100,color:#fff
        Serial["Serial Output<br/>(RS-232/USB)<br/>Power, Rods, Temps"]
    end
    
    subgraph Collection["DATA COLLECTION"]
        style Collection fill:#1565c0,color:#fff
        Collector["Data Collector<br/>(Python @ 1Hz)<br/>Buffer, Timestamp, CSV"]
        Watcher["File Watcher<br/>(Dagster @ 5min)<br/>Detect, Trigger"]
    end
    
    subgraph Pipeline["MEDALLION PIPELINE"]
        style Pipeline fill:#2e7d32,color:#fff
        Bronze["BRONZE<br/>reactor_timeseries_raw<br/>Append, Partition"]
        Silver["SILVER<br/>reactor_readings<br/>Validate, Impute"]
        Gold["GOLD<br/>reactor_hourly_metrics<br/>Aggregate, KPIs"]
    end
    
    subgraph Output["CONSUMPTION"]
        style Output fill:#7b1fa2,color:#fff
        Superset["SUPERSET<br/>Ops Dashboard<br/>Power, Rods, Temps"]
    end
    
    subgraph Audit["AUDIT TRAIL"]
        style Audit fill:#424242,color:#fff
        Merkle["Compute Merkle Hash"]
        Fabric["Hyperledger Fabric"]
    end
    
    Serial -->|1 Hz| Collector
    Collector -->|5 min| Watcher
    Watcher --> Bronze
    Bronze --> Silver
    Silver --> Gold
    Gold --> Superset
    Bronze -.-> Merkle
    Merkle --> Fabric
