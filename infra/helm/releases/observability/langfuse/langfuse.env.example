# LangFuse env-var template — copy to ~/.config/axiom/langfuse-<project>.env
# on each operator / node, fill in the keys from the LangFuse UI
# (project → Settings → API Keys), chmod 600. One file per LangFuse project
# (e.g. langfuse-prague.env, langfuse-sandbox_dev1.env). Workspace .envrc
# sources the production one by default; opt-in by sourcing a different one
# in the active shell.
#
# Axiom's tracing reader: infra/tracing/env.py — auto-selects LangFuse backend
# whenever both LANGFUSE_PUBLIC_KEY and LANGFUSE_SECRET_KEY are set.

export LANGFUSE_PUBLIC_KEY="pk-lf-REPLACE-ME"
export LANGFUSE_SECRET_KEY="sk-lf-REPLACE-ME"

# Axiom uses LANGFUSE_HOST; LangFuse SDKs use LANGFUSE_BASE_URL.
# Set both — same value — so any consumer works.
export LANGFUSE_HOST="http://rascal.austin.utexas.edu:30030"
export LANGFUSE_BASE_URL="http://rascal.austin.utexas.edu:30030"
