flowchart TB
    subgraph Auth["AUTHENTICATION"]
        style Auth fill:#1565c0,color:#fff
        OIDC["OIDC (Keycloak)<br/>User login, SSO"]
        APIKeys["API Keys<br/>Data ingest, CI/CD"]
        ServiceAcct["Service Accounts<br/>K8s inter-svc auth"]
    end
    
    subgraph Authz["AUTHORIZATION (RBAC)"]
        style Authz fill:#2e7d32,color:#fff
        Admin["Admin<br/>Full, Config, Users"]
        Operator["Operator<br/>Elog CRUD<br/>Dashboard, Rod ops"]
        Researcher["Researcher<br/>Read data<br/>Dashboard, Notebooks"]
        Auditor["Auditor<br/>Audit queries<br/>Evidence"]
    end
    
    subgraph DataProt["DATA PROTECTION"]
        style DataProt fill:#e65100,color:#fff
        Encrypt["Encryption<br/>At rest: AES-256<br/>In transit: TLS 1.3"]
        Integrity["Integrity<br/>Merkle proofs<br/>Blockchain audit"]
        Classification["Classification<br/>Public → Internal<br/>Confidential → Restricted"]
    end
    
    subgraph RLS["ROW-LEVEL SECURITY"]
        style RLS fill:#7b1fa2,color:#fff
        MeetingRLS["Meeting Data RLS<br/>PostgreSQL policies<br/>Attendee-only access"]
    end
    
    Auth --> Authz
    Authz --> DataProt
    Authz --> RLS
