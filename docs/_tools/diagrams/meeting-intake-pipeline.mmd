flowchart TB
    subgraph Input["INPUT"]
        style Input fill:#424242,color:#fff
        Meeting["Meeting<br/>(Zoom/Teams)"]
        Audio["Audio File<br/>(Uploaded)"]
    end
    
    subgraph LangGraph["LANGGRAPH AGENT WORKFLOW"]
        style LangGraph fill:#7b1fa2,color:#fff
        Transcribe["TRANSCRIBE<br/>(Whisper)<br/>Local GPU, Diarize"]
        Parse["PARSE<br/>(Claude)<br/>Topics, Actions"]
        Match["MATCH<br/>(pgvector)<br/>Find Related Issues"]
        Draft["DRAFT<br/>(Claude)<br/>Generate GitLab"]
    end
    
    subgraph Review["HUMAN REVIEW"]
        style Review fill:#e65100,color:#fff
        HumanReview["Review Draft<br/>Edit/Approve<br/>Select Action"]
    end
    
    subgraph Actions["GITLAB ACTIONS"]
        style Actions fill:#1565c0,color:#fff
        Append["APPEND to<br/>Existing Issue<br/>(Preferred)"]
        Create["CREATE New<br/>GitLab Issue<br/>(if no match)"]
    end
    
    subgraph Storage["DATA STORAGE"]
        style Storage fill:#2e7d32,color:#fff
        Postgres["PostgreSQL<br/>+ pgvector<br/>Embeddings, RLS"]
        Iceberg["Apache Iceberg<br/>Transcripts<br/>Action Items"]
        Fabric["Hyperledger<br/>Fabric<br/>Audit Trail"]
    end
    
    Meeting --> Audio
    Audio --> Transcribe
    Transcribe --> Parse
    Parse --> Match
    Match --> Draft
    Draft --> HumanReview
    HumanReview --> Append
    HumanReview --> Create
    Append --> Storage
    Create --> Storage
