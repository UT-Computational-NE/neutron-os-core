flowchart TB
    subgraph Morning["MORNING SHIFT START"]
        style Morning fill:#1565c0,color:#fff
        A1["7:00 AM<br/>Start Shift"]
        A2["Open Ops Dashboard<br/>View overnight power<br/>Check anomalies<br/>Review rod positions"]
        B1["7:30 AM<br/>Log Shift Start"]
        B2["Create Elog Entry<br/>Enter shift start<br/>Note handoff issues<br/>Auto-hash to chain"]
    end
    
    subgraph Midday["OPERATIONS MONITORING"]
        style Midday fill:#2e7d32,color:#fff
        C1["9:00 AM<br/>Monitor Startup"]
        C2["Real-time Dashboard<br/>Watch power ramp<br/>Monitor temps<br/>Track rod movement"]
        D1["12:00 PM<br/>Log Observation"]
        D2["Quick Elog Entry<br/>Note rod calibration<br/>Attach data ref<br/>Blockchain commit"]
    end
    
    subgraph EndShift["SHIFT END"]
        style EndShift fill:#e65100,color:#fff
        E1["3:00 PM<br/>End Shift"]
        E2["Close Elog + Handoff<br/>Summary entry<br/>Shift metrics auto<br/>Handoff notes"]
    end
    
    A1 --> A2 --> B1 --> B2 --> C1 --> C2 --> D1 --> D2 --> E1 --> E2
