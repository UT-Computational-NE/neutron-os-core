flowchart TB
    Start["START<br/>(Audio File Input)"]
    
    subgraph Workflow["LangGraph Workflow"]
        style Workflow fill:#7b1fa2,color:#fff
        Transcribe["TranscribeNode<br/>Tool: Whisper<br/>Output: transcript"]
        Parse["ParseNode<br/>Tool: Claude<br/>topics, actions, decisions"]
        Match["MatchNode<br/>Tool: pgvector<br/>Find related issues"]
    end
    
    subgraph Decision["ROUTING DECISION"]
        style Decision fill:#e65100,color:#fff
        MatchFound{"sim > 0.8?"}
        DraftAppend["DraftAppendNode<br/>Comment for<br/>existing issue"]
        DraftCreate["DraftCreateNode<br/>New issue draft"]
    end
    
    subgraph Execute["EXECUTION"]
        style Execute fill:#2e7d32,color:#fff
        HumanReview["HumanReviewNode<br/>INTERRUPT<br/>Await approval"]
        ExecuteNode["ExecuteNode<br/>GitLab API POST"]
        EndNode["END<br/>Store in Iceberg"]
    end
    
    Start --> Transcribe
    Transcribe --> Parse
    Parse --> Match
    Match --> MatchFound
    MatchFound -->|Yes| DraftAppend
    MatchFound -->|No| DraftCreate
    DraftAppend --> HumanReview
    DraftCreate --> HumanReview
    HumanReview --> ExecuteNode
    ExecuteNode --> EndNode
