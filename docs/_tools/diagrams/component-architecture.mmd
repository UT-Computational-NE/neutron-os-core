flowchart TB
    subgraph Packages["PACKAGES (Shared Libraries)"]
        style Packages fill:#1565c0,color:#fff
        Core["neutron-core<br/>Config, Logging<br/>Utilities"]
        Schemas["neutron-schemas<br/>Avro, Validation<br/>Evolution"]
        Audit["neutron-audit<br/>Fabric SDK<br/>Merkle, Proofs"]
        Parsers["neutron-parsers<br/>MPACT, SAM<br/>Nek5000"]
    end
    
    subgraph Services["SERVICES (Deployable)"]
        style Services fill:#2e7d32,color:#fff
        API["api-gateway<br/>FastAPI, Auth<br/>Routing"]
        Meeting["meeting-intake<br/>LangGraph<br/>Whisper, Claude"]
        Collector["data-collector<br/>Dagster, dbt<br/>Iceberg"]
        AuditSvc["audit-service<br/>Fabric Node<br/>REST, Verify"]
    end
    
    subgraph Plugins["PLUGINS (Project-Specific)"]
        style Plugins fill:#7b1fa2,color:#fff
        TRIGA["triga-plugin<br/>Schemas, Transforms<br/>Dashboards"]
        MSR["msr-plugin<br/>Schemas, Transforms<br/>Dashboards"]
        MIT["mit-loop-plugin<br/>Schemas, Transforms<br/>Dashboards"]
        OffGas["offgas-plugin<br/>Schemas, Transforms<br/>Dashboards"]
    end
    
    subgraph Infra["INFRASTRUCTURE"]
        style Infra fill:#424242,color:#fff
        Terraform["terraform/<br/>AWS/GCP<br/>Networking, IAM"]
        Helm["helm/<br/>Superset, Dagster<br/>PostgreSQL"]
        Docker["docker/<br/>Dockerfiles<br/>Base images"]
        K8s["k8s/<br/>Manifests, CRDs<br/>Operators"]
    end
    
    Packages --> Services
    Services --> Plugins
    Infra --> Services
